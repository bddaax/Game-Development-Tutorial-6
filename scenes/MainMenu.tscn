[sub_resource type="GDScript" id="GDScript_walker"]
script/source = "extends Node2D

@onready var animator = $Animator
@onready var sprite = $Sprite2D

func _ready():
	if animator and animator.has_animation(\"Walk\"):
		animator.play(\"Walk\")

func _process(_delta):
	if animator and animator.has_animation(\"Walk\") and animator.current_animation != \"Walk\":
		animator.play(\"Walk\")
"

